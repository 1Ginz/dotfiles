{
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/hooks/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "mina@mina": true
  },
  "extraKnownMarketplaces": {
    "mina": {
      "source": {
        "source": "github",
        "repo": "astronaut1712/astronaut-ai"
      }
    }
  },
  "theme": "dark",
  "skipWorkflowUsageWarning": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \"/Users/ginz\" || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/ginz/.claude/hooks/gsd-graphify-update.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/ginz/.claude/hooks/gsd-phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph status --repo \"/Users/ginz\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/ginz/.claude/hooks/gsd-session-state.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-update-banner.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-read-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/ginz/.nvm/versions/node/v24.16.0/bin/node\" \"/Users/ginz/.claude/hooks/gsd-workflow-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/ginz/.claude/hooks/gsd-validate-commit.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
