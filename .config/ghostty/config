# Theme — matches alacritty catppuccin_mocha.toml
theme = Catppuccin Mocha

# Font — matches alacritty
font-family = JetBrainsMono Nerd Font
font-size = 17

# Background — matches alacritty opacity = 0.7, blur = true
background-opacity = 0.7
background-blur-radius = 20

# Window — matches alacritty decorations = "Buttonless"
macos-titlebar-style = hidden

# Padding — matches alacritty dynamic_padding = true
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

# Input
macos-option-as-alt = true
mouse-hide-while-typing = true
